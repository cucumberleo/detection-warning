{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DetectionResultV1",
  "type": "object",
  "required": [
    "id",
    "device_id",
    "gas_type",
    "concentration_ppm",
    "confidence",
    "response",
    "status",
    "algorithm_version",
    "processing_latency_ms",
    "created_at",
    "curve"
  ],
  "properties": {
    "id": { "type": "string" },
    "device_id": { "type": "string" },
    "gas_type": { "enum": ["NH3", "Toluene", "HCHO", "TEA"] },
    "concentration_ppm": { "type": "number", "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "response": { "type": "number" },
    "status": { "enum": ["safe", "warning"] },
    "algorithm_version": { "type": "string" },
    "processing_latency_ms": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "curve": {
      "type": "object",
      "required": ["time", "values", "unit"],
      "properties": {
        "time": { "type": "array", "items": { "type": "number" } },
        "values": { "type": "array", "items": { "type": "number" } },
        "unit": { "const": "nA" }
      }
    }
  }
}
